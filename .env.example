NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vaxis
REDIS_URL=redis://127.0.0.1:6379
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
COOKIE_SECRET=change-me-before-production-cookie
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
JWT_SECRET=change-me-before-production-jwt
MFA_ENCRYPTION_SECRET=change-me-before-production-mfa
APP_ENCRYPTION_SECRET=change-me-before-production-app
APP_BASE_URL=http://localhost:5173
WEBHOOK_TIMEOUT_MS=5000
EMAIL_TRANSPORT=SMTP
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=no-reply@v-axis.local
EMAIL_FROM_NAME=V-AXIS
VAULT_STORAGE_ROOT=.data/vault
JOB_DELIVERY_MODE=QUEUE
WORKER_DELIVERY_CONCURRENCY=5
WORKER_GOVERNANCE_REFRESH_INTERVAL_MS=900000
WORKER_ESCALATION_INTERVAL_MS=300000
