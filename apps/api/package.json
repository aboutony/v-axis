{
  "name": "@vaxis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "vault:init": "mkdir -p ../../storage/vault",
    "build": "tsup --config tsup.config.ts",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@vaxis/db": "file:../../packages/db",
    "@vaxis/domain": "file:../../packages/domain",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.71.1",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.3",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.4",
    "otplib": "^12.0.1",
    "pg": "^8.16.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "^23.11.1",
    "qrcode": "^1.5.4",
    "tesseract.js": "^5.1.1",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  }
}
