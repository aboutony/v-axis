    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@vaxis/db": "file:../../packages/db",
    "@vaxis/domain": "file:../../packages/domain",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.0",
    "fastify": "^5.3.3",
    "nodemailer": "^8.0.4",
    "otplib": "^12.0.1",
    "pg": "^8.16.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6"
